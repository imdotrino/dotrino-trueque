# Cadena de suministro — endurecimiento (Dotrino). Ver CONVENCIONES-APPS.md §1.1.
# No ejecutar lifecycle scripts de dependencias (preinstall/install/postinstall):
# es el vector #1 de inyección en ataques npm. Verificado en esta plataforma:
# vite/esbuild y sharp instalan y funcionan igual con esto activo.
ignore-scripts=true
# Instalar versiones EXACTAS (sin ^ ni ~): evita el drift silencioso a un release
# recién publicado y potencialmente comprometido. Subir de versión queda explícito;
# el package-lock.json manda.
save-exact=true
# Sin telemetría de funding en la salida de install.
fund=false
